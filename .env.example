# Configuración de la base de datos para Docker Compose
POSTGRES_DB=steamlike
POSTGRES_USER=usuario
POSTGRES_PASSWORD=password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Configuración Django
DJANGO_SECRET_KEY=cambiame-en-produccion
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Caché Redis
REDIS_URL=redis://redis:6379/1

# CORS / CSRF
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:5173
